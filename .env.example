# Existing MySQL server connection for backend
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=your_mysql_user
DB_PASSWORD=your_mysql_password
DB_NAME=accountsystem

# JWT
JWT_SECRET=replace_with_a_long_random_secret

# Optional: only needed when using docker-compose mysql/phpmyadmin
MYSQL_ROOT_PASSWORD=replace_with_mysql_root_password
MYSQL_DATABASE=accountsystem
MYSQL_USER=your_app_db_user
MYSQL_PASSWORD=your_app_db_password

# Optional phpMyAdmin target credentials
PMA_HOST=mysql
PMA_USER=your_app_db_user
PMA_PASSWORD=your_app_db_password