/**pages/accounts/accounts.wxss**/
.container {
  padding: 20px;
}

.title {
  font-size: 24px;
  font-weight: bold;
  margin-bottom: 20px;
}

.accounts-list {
  display: flex;
  flex-direction: column;
  gap: 10px;
}

.account-item {
  border: 1px solid #ddd;
  padding: 15px;
  border-radius: 5px;
  display: flex;
  justify-content: space-between;
}

.account-name {
  font-weight: bold;
}

.account-balance {
  color: #007AFF;
}

.add-btn {
  background-color: #007AFF;
  color: white;
  padding: 12px;
  border-radius: 5px;
  margin-top: 20px;
}
