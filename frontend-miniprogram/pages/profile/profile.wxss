/**pages/profile/profile.wxss**/
.container {
  padding: 20px;
}

.title {
  font-size: 24px;
  font-weight: bold;
  margin-bottom: 20px;
}

.profile-item {
  display: flex;
  justify-content: space-between;
  padding: 15px 0;
  border-bottom: 1px solid #ddd;
}

.label {
  font-weight: bold;
}

.value {
  color: #666;
}

.logout-btn {
  background-color: #ff3333;
  color: white;
  padding: 12px;
  border-radius: 5px;
  margin-top: 30px;
}
