/**pages/transactions/transactions.wxss**/
.container {
  padding: 20px;
}

.title {
  font-size: 24px;
  font-weight: bold;
  margin-bottom: 20px;
}

.transactions-list {
  display: flex;
  flex-direction: column;
  gap: 10px;
}

.transaction-item {
  border: 1px solid #ddd;
  padding: 15px;
  border-radius: 5px;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.transaction-category {
  font-weight: bold;
  display: block;
}

.transaction-desc {
  font-size: 12px;
  color: #666;
  display: block;
}

.transaction-amount {
  font-weight: bold;
  font-size: 14px;
}

.income {
  color: green;
}

.expense {
  color: red;
}
