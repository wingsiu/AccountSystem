/**pages/index/index.wxss**/
.container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 20px;
  height: 100vh;
}

.title {
  font-size: 32px;
  font-weight: bold;
  margin-bottom: 10px;
}

.subtitle {
  font-size: 14px;
  color: #666;
  margin-bottom: 30px;
}

.button-group {
  display: flex;
  flex-direction: column;
  width: 100%;
  gap: 10px;
}

button {
  background-color: #007AFF;
  color: white;
  padding: 12px;
  border-radius: 5px;
  margin-top: 10px;
}
